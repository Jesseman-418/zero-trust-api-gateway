# Gateway Configuration
GATEWAY_PORT=3002
UPSTREAM_PORT=4001

# JWKS Configuration
JWKS_URI=https://your-okta-domain.okta.com/oauth2/default/v1/keys
JWT_ISSUER=https://your-okta-domain.okta.com/oauth2/default
JWT_AUDIENCE=api://default

# Token Introspection (RFC 7662)
INTROSPECTION_ENDPOINT=https://your-okta-domain.okta.com/oauth2/default/v1/introspect
INTROSPECTION_CLIENT_ID=your-client-id
INTROSPECTION_CLIENT_SECRET=your-client-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Security
HMAC_SECRET=your-hmac-secret-for-request-signing
REQUEST_BODY_MAX_SIZE=1mb

# mTLS
MTLS_ENABLED=false
MTLS_CA_CERT_PATH=./certs/ca.pem
MTLS_CERT_PATH=./certs/server.pem
MTLS_KEY_PATH=./certs/server-key.pem

# Logging
LOG_LEVEL=info
AUDIT_LOG_PATH=./audit-logs

# Demo Mode (uses self-signed JWTs for testing)
DEMO_MODE=true
DEMO_JWT_SECRET=demo-secret-key-change-in-production
